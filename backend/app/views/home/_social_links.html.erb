<div class="flex flex-wrap gap-4 justify-center mt-6">
  <% links.each do |key, data| %>
    <% url = data[:url] %>
    <% next if url.blank? %>
    <%= link_to url, target: "_blank", rel: "noopener noreferrer", class: "flex items-center font-semibold gap-2 px-4 py-2 bg-red-400 text-white rounded-lg hover:bg-yellow-300 transition-colors cursor-pointer" do %>
      <% if data[:img].present? %>
        <%= image_tag data[:img], alt: key.to_s, class: "w-5 h-5 object-contain", loading: "lazy" %>
      <% elsif data[:icon].present? %>
        <span><%= data[:icon] %></span>
      <% end %>
      <span><%= social_link_label(key) %></span>
    <% end %>
  <% end %>
</div>
