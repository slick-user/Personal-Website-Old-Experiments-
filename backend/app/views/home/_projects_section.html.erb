<section
  class="mt-20 py-10 px-4 bg-gradient-to-b from-horizon3/20 to-sunPaleYellow/70 rounded-3xl overflow-visible"
  data-controller="projects-rail"
>
  <h2 class="text-4xl font-extrabold text-horizon1 text-center mb-12 uppercase tracking-wider">
    Featured Projects
  </h2>

  <div class="relative flex items-center max-w-7xl mx-auto px-4">
    <button
      type="button"
      data-action="projects-rail#scrollPrev"
      class="absolute -left-4 z-50 px-5 py-4 bg-horizon1 text-white rounded-full shadow-xl hover:bg-wallsMaroon transition-all border-2 border-white focus:outline-none cursor-pointer"
      aria-label="Scroll projects left"
    >
      ←
    </button>

    <div
      data-projects-rail-target="rail"
      class="flex gap-10 overflow-x-auto no-scrollbar flex-1 py-20 px-10 scroll-smooth overflow-visible"
    >
      <% projects.each do |project| %>
        <div class="group relative flex-shrink-0 w-72 h-80 cursor-pointer">
          <div class="relative w-full h-full bg-gray-900 rounded-2xl overflow-hidden transition-all duration-500 ease-out border-2 border-white/20 shadow-lg z-10 group-hover:scale-125 group-hover:z-40 group-hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)] group-hover:border-horizon1">
            <div class="absolute inset-0 w-full h-full">
              <% if project[:img].blank? && project[:gif].blank? %>
                <div class="w-full h-full bg-gradient-to-br from-gray-800 to-horizon1 flex items-center justify-center">
                  <span class="text-white text-4xl font-black opacity-50"><%= project[:title].to_s.first %></span>
                </div>
              <% else %>
                <% if project[:img].present? %>
                  <%= image_tag project[:img], alt: project[:title], class: "w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:blur-[1px] group-hover:opacity-40 #{'group-hover:opacity-0' if project[:gif].present?}" %>
                <% end %>
                <% if project[:gif].present? %>
                  <%= image_tag project[:gif], alt: "#{project[:title]} demo", class: "w-full h-full object-cover absolute top-0 left-0 transition-opacity duration-500 group-hover:opacity-100 group-hover:scale-110 #{project[:img].present? ? 'opacity-0' : 'opacity-100'}" %>
                <% end %>
              <% end %>

              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-60 transition-opacity duration-500 group-hover:opacity-80"></div>
            </div>

            <div class="relative h-full w-full p-6 flex flex-col justify-end items-start z-10">
              <h3 class="font-black text-2xl text-white transition-all duration-500 ease-in-out transform leading-tight translate-y-0 group-hover:-translate-y-24 group-hover:text-horizon4">
                <%= project[:title] %>
              </h3>

              <p class="absolute bottom-8 left-6 right-16 text-sm text-gray-200 font-medium leading-snug transition-all duration-500 opacity-0 translate-y-4 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0">
                <%= project[:description] %>
              </p>

              <% if project[:link].present? %>
                <%= link_to project[:link], target: "_blank", rel: "noopener noreferrer", class: "absolute bottom-6 right-4 p-3 bg-white text-horizon1 rounded-full shadow-2xl transition-all duration-500 transform scale-0 opacity-0 -rotate-90 pointer-events-none group-hover:scale-100 group-hover:opacity-100 group-hover:rotate-0 group-hover:pointer-events-auto hover:bg-horizon1 hover:text-white cursor-pointer" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <button
      type="button"
      data-action="projects-rail#scrollNext"
      class="absolute -right-4 z-50 px-5 py-4 bg-horizon1 text-white rounded-full shadow-xl hover:bg-wallsMaroon transition-all border-2 border-white focus:outline-none cursor-pointer"
      aria-label="Scroll projects right"
    >
      →
    </button>
  </div>
</section>
