<section class="mt-12 px-8 py-10 bg-horizon4 rounded-3xl">
  <h2 class="text-4xl font-extrabold bg-gradient-to-r from-horizon1 to-horizon3 text-transparent bg-clip-text text-center mb-12">
    Certifications
  </h2>

  <div class="flex flex-col gap-12 max-w-5xl mx-auto">
    <% certifications.each do |cert| %>
      <div class="flex flex-col">
        <div class="flex items-center gap-6 mb-6">
          <h3 class="text-2xl font-bold text-black whitespace-nowrap">
            <%= cert[:title] %>
          </h3>
          <div class="flex-grow border-t-2 border-horizon2"></div>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-8 bg-gradient-to-r from-orange-50 to-yellow-50 rounded-2xl p-8 shadow-xl transition-transform hover:scale-[1.01]">
          <div class="w-full md:w-2/4 flex-shrink-0">
            <% if cert[:img].present? %>
              <%= image_tag cert[:img], alt: cert[:title], class: "w-full h-auto object-contain rounded-lg shadow-md border-4 border-white/10" %>
            <% end %>
          </div>

          <div class="flex flex-col flex-1 justify-center space-y-4 h-full">
            <div class="space-y-1">
              <p class="text-xl text-horizon1">
                <span class="font-semibold text-black">Date:</span> <u><%= cert[:date] %></u>
              </p>
              <p class="text-xl text-horizon1">
                <span class="font-semibold text-black">Issuer:</span> <u><%= cert[:issuer] %></u>
              </p>

              <% if cert[:link].present? %>
                <%= link_to "Verify Certificate", cert[:link], target: "_blank", rel: "noopener noreferrer", class: "mt-4 inline-block w-fit px-8 py-3 bg-horizon1 text-white rounded-xl font-bold text-lg hover:bg-wallsMaroon transition-all shadow-lg active:transform active:scale-95 cursor-pointer" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
